.wrap {
  min-height: 100vh;
  padding: calc(48rpx + env(safe-area-inset-top, 0px)) 40rpx calc(80rpx + env(safe-area-inset-bottom, 0px));
  box-sizing: border-box;
}

.hero {
  margin-bottom: 56rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 600;
  letter-spacing: 0.2em;
  margin-bottom: 24rpx;
}

.sub {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(232, 228, 220, 0.72);
}

.btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #8b7355, #5c4d3a);
  color: #f5f0e6;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
  letter-spacing: 0.15em;
}

.btn[disabled] {
  opacity: 0.45;
}

.tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #c9a227;
  line-height: 1.6;
}

.hint {
  margin-top: 40rpx;
  font-size: 22rpx;
  color: rgba(232, 228, 220, 0.45);
  line-height: 1.6;
}
