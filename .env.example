# --- Web 端投稿登录（Supabase Auth · Magic Link；与下方服务端同一 Supabase 项目）---
# 构建时会打入前端，使用 anon key（可公开）
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=

# 必填：在 Coze 开放平台创建 PAT（个人访问令牌）
COZE_TOKEN=
# 必填：已发布且开启 API 渠道的智能体 Bot ID
COZE_BOT_ID=7624172480504594467

# 可选：默认国际版 https://api.coze.com；国内版可设为 https://api.coze.cn 或 COZE_REGION=cn
# COZE_BASE_URL=https://api.coze.com
COZE_REGION=cn

# 可选：区分终端用户，便于 Coze 侧统计（可改为 openid）
COZE_USER_ID=turtle-soup-guest

PORT=3000

# --- 投稿审核（仅配置在 Vercel 项目 Environment Variables，勿提交密钥）---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=（必须用 service_role，不要用 anon）
# ADMIN_SECRET=（随机长字符串；与下方本机跑审核脚本时 export 的值一致）
#
# --- 微信小程序登录（与上方同项目配置；配置后投稿接口须携带登录 JWT）---
# JWT_SECRET=（随机字符串，建议 ≥32 字符；用于签发 ticket / access token）
# WECHAT_MINI_APPID=（公众平台小程序 AppID）
# WECHAT_MINI_SECRET=（公众平台小程序 AppSecret）
# 并在 Supabase 执行 migrations/002_submitter_openid.sql 增加 submitter_openid 列
#
# 本机执行 scripts/admin-review.sh 时另在 shell 中设置（勿写入本文件）：
#   export ORIGIN=https://你的生产根域名
#   export ADMIN_SECRET=与 Vercel 中相同

# 本地 npm run dev 时请求已部署的 Vercel API（无尾斜杠）
# VITE_API_BASE=https://your-app.vercel.app